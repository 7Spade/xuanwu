{
	"servers": {
		"repomix": {
			"command": "npx",
			"args": [
				"-y",
				"repomix",
				"--mcp"
			],
			"type": "stdio"
		},
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },

		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		}
	},
	"inputs": []
}