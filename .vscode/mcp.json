{
	"inputs": [],
	"servers": {
		"repomix": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"repomix",
				"--mcp"
			]
		},
		"ESLint": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@eslint/mcp@latest"
			]
		},
		"next-devtools": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"next-devtools-mcp@latest"
			]
		},
		"shadcn": {
			"command": "npx",
			"args": [
				"shadcn@latest",
				"mcp"
			],
			"type": "stdio"
		},
		"memory": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-memory"
			],
			"env": {
				"MEMORY_FILE_PATH": "./docs/knowledge-graph.json"
			}
		},
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"."
			]
		}
	}
}