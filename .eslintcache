/utility-hooks/use-toast\";\nimport { type Team, type WorkspaceRole, type MemberReference } from \"@/shared/types\";\nimport { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from \"@/shared/shadcn-ui/dialog\";\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/shared/shadcn-ui/select\";\nimport { Label } from \"@/shared/shadcn-ui/label\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { Tabs, TabsContent, TabsList, TabsTrigger } from \"@/shared/shadcn-ui/tabs\";\n",[584,1153],"import { type Team, type WorkspaceRole, type MemberReference } from \"@/shared/types\";\nimport { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from \"@/shared/shadcn-ui/dialog\";\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/shared/shadcn-ui/select\";\nimport { Label } from \"@/shared/shadcn-ui/label\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { toast } from \"@/shared/utility-hooks/use-toast\";\n",[642,1153],"import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from \"@/shared/shadcn-ui/dialog\";\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/shared/shadcn-ui/select\";\nimport { Label } from \"@/shared/shadcn-ui/label\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { type Team, type WorkspaceRole, type MemberReference } from \"@/shared/types\";\n",[728,1153],"import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/shared/shadcn-ui/select\";\nimport { Label } from \"@/shared/shadcn-ui/label\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { Dialog, DialogContent, DialogHeader, DialogTitle, DialogFooter } from \"@/shared/shadcn-ui/dialog\";\n",[836,1153],"import { Label } from \"@/shared/shadcn-ui/label\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from \"@/shared/shadcn-ui/select\";\n",[943,1153],"import { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\nimport { cn } from \"@/shared/lib\";\nimport { Label } from \"@/shared/shadcn-ui/label\";\n",[993,1153],"import { cn } from \"@/shared/lib\";\nimport { DropdownMenu, DropdownMenuContent, DropdownMenuItem, DropdownMenuTrigger } from \"@/shared/shadcn-ui/dropdown-menu\";\n",[410,646],"import {\n  type CommandResult,\n  commandSuccess,\n  commandFailureFrom,\n} from '@/features/shared-kernel';\nimport {\n  grantIndividualWorkspaceAccess,\n  revokeIndividualWorkspaceAccess,\n} from '@/shared/infra/firestore/firestore.facade';\n",[192,192],[241,241],[193,296],"import type { WorkspaceGrant } from '@/shared/types';\nimport { getWorkspaceGrant } from '../_queries';\n",[697,805],"import type React from 'react'\nimport { type ReactNode, createContext, useReducer, useEffect } from 'react'\n",[898,898],[697,899],"import { collection, query, where, onSnapshot, type QuerySnapshot } from 'firebase/firestore'\nimport { type ReactNode, createContext, useReducer, useEffect } from 'react'\nimport type React from 'react'\n",[990,990],[899,991],"import { useAuth } from './auth-provider'\nimport { useFirebase } from './firebase-provider'\n",[899,1067],"import { snapshotToRecord } from '@/shared/infra/firestore/firestore.utils'\nimport { useFirebase } from './firebase-provider'\nimport { useAuth } from './auth-provider'\n",[899,1153],"import { type Account, type CapabilitySpec, type Notification } from '@/shared/types'\nimport { useFirebase } from './firebase-provider'\nimport { useAuth } from './auth-provider'\nimport { snapshotToRecord } from '@/shared/infra/firestore/firestore.utils'\n",[899,7463],"import { useContext } from 'react'\nimport { useFirebase } from './firebase-provider'\nimport { useAuth } from './auth-provider'\nimport { snapshotToRecord } from '@/shared/infra/firestore/firestore.utils'\nimport { type Account, type CapabilitySpec, type Notification } from '@/shared/types'\n\n// ---------------------------------------------------------------------------\n// State shape\n// ---------------------------------------------------------------------------\n\nexport interface AppState {\n  accounts: Record<string, Account>\n  activeAccount: Account | null\n  notifications: Notification[]\n  capabilitySpecs: CapabilitySpec[]\n  scheduleTaskRequest: { taskName: string; workspaceId: string } | null\n}\n\nexport type AppAction =\n  | { type: 'SET_ACCOUNTS'; payload: { snapshot: QuerySnapshot; user: Account } }\n  | { type: 'SET_ACTIVE_ACCOUNT'; payload: Account | null }\n  | { type: 'RESET_STATE' }\n  | { type: 'ADD_NOTIFICATION'; payload: Omit<Notification, 'id' | 'timestamp' | 'read'> }\n  | { type: 'MARK_NOTIFICATION_READ'; payload: string }\n  | { type: 'CLEAR_NOTIFICATIONS' }\n  | { type: 'REQUEST_SCHEDULE_TASK'; payload: { taskName: string; workspaceId: string } }\n  | { type: 'CLEAR_SCHEDULE_TASK_REQUEST' }\n\n// ---------------------------------------------------------------------------\n// Initial state\n// ---------------------------------------------------------------------------\n\nconst initialState: AppState = {\n  accounts: {},\n  activeAccount: null,\n  notifications: [],\n  capabilitySpecs: [\n    { id: 'capabilities', name: 'Capabilities', type: 'ui', status: 'stable', description: 'Manage the atomic capabilities mounted to this workspace.' },\n    { id: 'members', name: 'Members', type: 'governance', status: 'stable', description: 'Manages granular, grant-based authorization for teams and individuals.' },\n    { id: 'audit', name: 'Audit', type: 'monitoring', status: 'stable', description: 'Provides a real-time event stream for all significant state changes.' },\n    { id: 'tasks', name: 'Tasks', type: 'ui', status: 'stable', description: 'Track concrete action items within the workspace node.' },\n    { id: 'quality-assurance', name: 'QA', type: 'ui', status: 'stable', description: 'Governance unit for verifying the quality of atomic data execution.' },\n    { id: 'acceptance', name: 'Acceptance', type: 'ui', status: 'stable', description: 'Accept workspace deliverables and terminate A-Track resonance.' },\n    { id: 'finance', name: 'Finance', type: 'ui', status: 'beta', description: 'Track dimension budgets and post-acceptance fund disbursement.' },\n    { id: 'issues', name: 'Issues', type: 'ui', status: 'stable', description: 'Governance module for handling technical conflicts and B-Track anomalies.' },\n    { id: 'daily', name: 'Daily', type: 'ui', status: 'stable', description: 'A minimalist activity wall for technical collaboration within the space.' },\n    { id: 'files', name: 'Files', type: 'data', status: 'stable', description: 'Manage document sovereignty and technical assets within the dimension.' },\n    { id: 'schedule', name: 'Schedule', type: 'ui', status: 'stable', description: 'View and manage the adoption timeline for the workspace.' },\n    { id: 'document-parser', name: 'Document Parser', type: 'ui', status: 'beta', description: 'Intelligently parse and extract data from documents like invoices and quotes.' },\n  ],\n  scheduleTaskRequest: null,\n}\n\n// ---------------------------------------------------------------------------\n// Reducer\n// ---------------------------------------------------------------------------\n\nfunction appReducer(state: AppState, action: AppAction): AppState {\n  switch (action.type) {\n    case 'SET_ACTIVE_ACCOUNT':\n      if (state.activeAccount?.id === action.payload?.id) return state\n      return { ...state, activeAccount: action.payload }\n\n    case 'RESET_STATE':\n      return initialState\n\n    case 'SET_ACCOUNTS': {\n      const { snapshot, user } = action.payload\n      if (!snapshot?.docs) return state\n      const newAccounts = snapshotToRecord<Account>(snapshot)\n      let newActiveAccount = state.activeAccount\n      const availableAccountIds = [user.id, ...Object.keys(newAccounts)]\n      if (!newActiveAccount || !availableAccountIds.includes(newActiveAccount.id)) {\n        newActiveAccount = user\n      }\n      return { ...state, accounts: newAccounts, activeAccount: newActiveAccount }\n    }\n\n    case 'ADD_NOTIFICATION': {\n      const newNotification = {\n        ...action.payload,\n        id: Math.random().toString(36).substring(2, 9),\n        timestamp: Date.now(),\n        read: false,\n      }\n      return {\n        ...state,\n        notifications: [newNotification, ...state.notifications].slice(0, 50),\n      }\n    }\n\n    case 'MARK_NOTIFICATION_READ':\n      return { ...state, notifications: state.notifications.map(n => n.id === action.payload ? { ...n, read: true } : n) }\n\n    case 'CLEAR_NOTIFICATIONS':\n      return { ...state, notifications: [] }\n\n    case 'REQUEST_SCHEDULE_TASK':\n      return { ...state, scheduleTaskRequest: action.payload }\n\n    case 'CLEAR_SCHEDULE_TASK_REQUEST':\n      return { ...state, scheduleTaskRequest: null }\n\n    default:\n      return state\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Context + Provider\n// ---------------------------------------------------------------------------\n\nexport const AppContext = createContext<{ state: AppState; dispatch: React.Dispatch<AppAction> } | null>(null)\n\nexport const AppProvider = ({ children }: { children: ReactNode }) => {\n  const { db } = useFirebase()\n  const { state: authState } = useAuth()\n  const { user, authInitialized } = authState\n  const [state, dispatch] = useReducer(appReducer, initialState)\n\n  useEffect(() => {\n    if (!authInitialized) return\n\n    let unsubscribe: (() => void) | null = null\n\n    if (user?.id && db) {\n      const accountQuery = query(collection(db, 'accounts'), where('memberIds', 'array-contains', user.id))\n      unsubscribe = onSnapshot(accountQuery, (snap) =>\n        dispatch({ type: 'SET_ACCOUNTS', payload: { snapshot: snap, user } })\n      )\n    } else {\n      dispatch({ type: 'RESET_STATE' })\n    }\n\n    return () => {\n      if (unsubscribe) unsubscribe()\n    }\n  }, [authInitialized, user, db])\n\n  return (\n    <AppContext.Provider value={{ state, dispatch }}>\n      {children}\n    </AppContext.Provider>\n  )\n}\n\n// ---------------------------------------------------------------------------\n// Hook\n// ---------------------------------------------------------------------------\n\n",[15,85],[217,217],[15,218],"import { type User as FirebaseUser } from \"firebase/auth\";\nimport {type ReactNode} from 'react';\nimport type React from 'react';\nimport { createContext, useReducer, useContext, useEffect } from 'react';\n",[15,284],"import { type FirebaseApp } from 'firebase/app';\nimport { type Firestore } from 'firebase/firestore';\nimport { type Auth } from 'firebase/auth';\nimport { type FirebaseStorage } from 'firebase/storage';\nimport { createContext, useContext, type ReactNode } from 'react';\n",[131,227],"import { type Auth } from 'firebase/auth';\nimport { type Firestore } from 'firebase/firestore';\n",[283,283],[333,453],[261,261],[214,309],"import { logEvent } from 'firebase/analytics';\nimport { analytics } from './analytics.client';\n",[363,363],[238,238],[254,254],[217,478],"import {\n  signInWithEmailAndPassword,\n  createUserWithEmailAndPassword,\n  sendPasswordResetEmail,\n  signInAnonymously,\n  updateProfile,\n  signOut,\n  onAuthStateChanged,\n  type User as FirebaseUser,\n} from 'firebase/auth';\nimport { auth } from './auth.client';\n",[193,193],[286,286],[199,199],[355,355],[382,382],[307,307],[434,434],[308,526],"import type {\n  Account,\n  MemberReference,\n  Team,\n  ThemeConfig,\n} from '@/shared/types'\nimport { db } from '../firestore.client'\nimport { updateDocument, addDocument, setDocument } from '../firestore.write.adapter'\n",[282,282],[437,437],[324,438],"import { createConverter } from '../firestore.converter'\nimport { getDocuments } from '../firestore.read.adapter'\n",[283,485],"import type { AuditLog } from '@/shared/types'\nimport { db } from '../firestore.client'\nimport { getDocuments } from '../firestore.read.adapter'\nimport { createConverter } from '../firestore.converter'\n",[416,416],[571,571],[458,572],[417,636],"import type { DailyLog, DailyLogComment } from '@/shared/types'\nimport { db } from '../firestore.client'\nimport { getDocuments } from '../firestore.read.adapter'\nimport { createConverter } from '../firestore.converter'\n",[454,454],[357,357],[399,529],"import { getDocuments } from '../firestore.read.adapter'\nimport { addDocument, updateDocument } from '../firestore.write.adapter'\n",[585,585],[399,586],"import { createConverter } from '../firestore.converter'\nimport { addDocument, updateDocument } from '../firestore.write.adapter'\nimport { getDocuments } from '../firestore.read.adapter'\n",[358,637],"import type { ScheduleItem } from '@/shared/types'\nimport { db } from '../firestore.client'\nimport { addDocument, updateDocument } from '../firestore.write.adapter'\nimport { getDocuments } from '../firestore.read.adapter'\nimport { createConverter } from '../firestore.converter'\n",[251,251],[349,349],[252,396],"import type { Account } from '@/shared/types'\nimport { db } from '../firestore.client'\nimport { setDocument } from '../firestore.write.adapter'\n",[561,561],[604,741],"import { getDocuments } from '../firestore.read.adapter';\nimport {\n  updateDocument,\n  addDocument,\n} from '../firestore.write.adapter';\n",[798,798],[604,799],"import { createConverter } from '../firestore.converter';\nimport {\n  updateDocument,\n  addDocument,\n} from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\n",[562,852],"import type { ParsingIntent } from '@/shared/types';\nimport { db } from '../firestore.client';\nimport {\n  updateDocument,\n  addDocument,\n} from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\nimport { createConverter } from '../firestore.converter';\n",[402,402],[445,577],"import { getDocuments } from '../firestore.read.adapter';\nimport { updateDocument, addDocument } from '../firestore.write.adapter';\n",[634,634],[445,635],"import { createConverter } from '../firestore.converter';\nimport { updateDocument, addDocument } from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\n",[403,710],"import type { WorkspaceFile, WorkspaceFileVersion } from '@/shared/types';\nimport { db } from '../firestore.client';\nimport { updateDocument, addDocument } from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\nimport { createConverter } from '../firestore.converter';\n",[407,407],[450,587],[644,644],[450,645],[408,713],"import type { WorkspaceIssue, IssueComment } from '@/shared/types';\nimport { db } from '../firestore.client';\nimport {\n  updateDocument,\n  addDocument,\n} from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\nimport { createConverter } from '../firestore.converter';\n",[386,386],[429,584],"import { getDocuments } from '../firestore.read.adapter';\nimport {\n  updateDocument,\n  addDocument,\n  deleteDocument,\n} from '../firestore.write.adapter';\n",[641,641],[429,642],"import { createConverter } from '../firestore.converter';\nimport {\n  updateDocument,\n  addDocument,\n  deleteDocument,\n} from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\n",[387,695],"import type { WorkspaceTask } from '@/shared/types';\nimport { db } from '../firestore.client';\nimport {\n  updateDocument,\n  addDocument,\n  deleteDocument,\n} from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\nimport { createConverter } from '../firestore.converter';\n",[479,479],[522,638],"import { getDocuments } from '../firestore.read.adapter';\nimport { addDocument } from '../firestore.write.adapter';\n",[522,696],"import { createConverter } from '../firestore.converter';\nimport { addDocument } from '../firestore.write.adapter';\nimport { getDocuments } from '../firestore.read.adapter';\n",[420,420],[559,559],[421,737],"import type {\n  Workspace,\n  WorkspaceRole,\n  WorkspaceGrant,\n  WorkspaceFile,\n  Capability,\n  WorkspaceLifecycleState,\n  Account,\n  WorkspaceLocation,\n} from '@/shared/types';\nimport { db } from '../firestore.client';\nimport {\n  updateDocument,\n  addDocument,\n  deleteDocument,\n} from '../firestore.write.adapter';\n",[337,337],[203,203],[208,323],"import { getFileDownloadURL } from './storage.read.adapter';\nimport { uploadFile } from './storage.write.adapter';\n",[256,256],[276,276],[120,246],"import { isOwner, getUserTeamIds } from \"@/shared/lib/account.rules\"\nimport type { Workspace, Account } from \"@/shared/types\"\n",[47,47],[0,96],"import type { Timestamp } from '@/shared/ports'\nimport type { SkillGrant } from './skill.types'\n",[103,103],[0,104],"import type { SkillRequirement } from './skill.types'\nimport type { Location } from './workspace.types'\n",[0,152],"import type { Timestamp } from '@/shared/ports'\nimport type { Location } from './workspace.types'\nimport type { SkillRequirement } from './skill.types'\n",[190,190],[306,306],[14,344],"import { Globe } from \"lucide-react\"\nimport { useI18n } from \"@/config/i18n/i18n-provider\"\nimport { type Locale } from \"@/config/i18n/i18n-types\"\nimport { Button } from \"@/shared/shadcn-ui/button\"\nimport {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuTrigger,\n} from \"@/shared/shadcn-ui/dropdown-menu\"\n",[2605,2763],"Update the dependencies array to be: [pendingParseFile, setPendingParseFile, triggerParseFromURL]",{"range":"7972","text":"7973"},"directive","","Update the dependencies array to be: []",{"range":"7974","text":"7975"},"Update the dependencies array to be: [eventBus, dispatch, workspace.id, workspace.dimensionId, workspace.name, logAuditEvent, updateTask, createScheduleItem]",{"range":"7976","text":"7977"},[5626,5628],"[pendingParseFile, setPendingParseFile, triggerParseFromURL]",[4790,4803],"[]",[11730,11830],"[eventBus, dispatch, workspace.id, workspace.dimensionId, workspace.name, logAuditEvent, updateTask, createScheduleItem]"]